{
  "name": "formflow-studio",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "bin": {
    "formflow": "bin/formflow",
    "formflow-mcp": "bin/formflow-mcp"
  },
  "scripts": {
    "dev": "vite ui",
    "dev:server": "tsx watch --clear-screen=false server/src/index.ts",
    "dev:provider": "node scripts/start-llm-provider.mjs",
    "dev:all": "concurrently --kill-others-on-fail \"npm run dev:provider\" \"cross-env FORMFLOW_MODE=local LLM_PROVIDER_GRPC_URL=127.0.0.1:50051 npm run dev:server\" \"cross-env VITE_APP_MODE=local npm run dev\"",
    "dev:cloud": "concurrently \"cross-env FORMFLOW_MODE=cloud npm run dev:server\" \"cross-env VITE_APP_MODE=cloud npm run dev\"",
    "server": "npx tsx server/src/index.ts",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit -p ui/tsconfig.json",
    "build": "vite build ui",
    "preview": "vite preview ui",
    "test:e2e": "playwright test --config ui/playwright.config.ts",
    "release": "semantic-release"
  },
  "dependencies": {
    "@antv/x6": "^3.1.7",
    "@antv/x6-react-shape": "^3.0.1",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@icon-park/react": "^1.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@xyflow/react": "^12.11.0",
    "ag-grid-community": "^35.3.1",
    "ag-grid-enterprise": "^35.3.1",
    "ag-grid-react": "^35.3.1",
    "antd": "^6.5.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.13",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.6",
    "monaco-editor": "^0.55.1",
    "mssql": "^12.7.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.6",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pinyin-pro": "3.28.1",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-router-dom": "^7.18.0",
    "sql.js": "^1.14.1",
    "tslib": "^2.8.1",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "semantic-release": "^25.0.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
