NODE_ENV=development
FORMFLOW_MODE=local
PORT=3001
VITE_API_BASE=/api
VITE_APP_MODE=local
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
JWT_SECRET=replace-with-at-least-32-random-characters
FORMFLOW_DATABASE_URL=postgresql://formflow:formflow-development-password@localhost:5432/formflow
FORMFLOW_DATABASE_REQUIRED=true
FORMFLOW_DATABASE_AUTO_START=true
FORMFLOW_POSTGRES_DATA_DIR=./server/data/postgres
FORMFLOW_POSTGRES_BIN_DIR=
FORMFLOW_HEALTH_INTERVAL_MS=10000
FORMFLOW_VECTOR_REQUIRED=false
# Optional HNSW indexes; comma-separated dimensions supported by the selected embedding models (maximum 2000 each)
FORMFLOW_VECTOR_INDEX_DIMENSIONS=1024,1536
POSTGRES_PASSWORD=formflow-development-password
FORMFLOW_DATA_DIR=./server/data
FORMFLOW_PROJECTS_DIR=./projects/data
PYTHON_EXECUTABLE=./venv/bin/python3
LLM_PROVIDER_GRPC_URL=127.0.0.1:50051
LLM_PROVIDER_NO_PROXY_HOSTS=token-plan-cn.xiaomimimo.com
LLM_PROVIDER_HTTP_URL=http://localhost:5001
LLM_PROVIDER_SERVICE_TOKEN=replace-with-a-random-service-token
LLM_CONFIG_MASTER_KEY=replace-with-at-least-32-random-characters
LLM_PROVIDER_DATABASE_URL=postgresql://formflow:formflow-development-password@localhost:5432/formflow
LLM_PROVIDER_CHECKPOINT_NAMESPACE=formflow:llm-provider
LLM_PROVIDER_CHECKPOINT_STORE_REQUIRED=false
LLM_PROVIDER_PLUGIN_DIR=./llm-provider/plugins
LLM_PROVIDER_PLUGIN_ALLOWLIST=
# Production mTLS paths (optional for localhost development)
LLM_PROVIDER_TLS_CA=
LLM_PROVIDER_TLS_CERT=
LLM_PROVIDER_TLS_KEY=
LLM_PROVIDER_TLS_SERVER_NAME=
LLM_PROVIDER_REQUIRE_MTLS=false
# Initial configuration migration only
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5
