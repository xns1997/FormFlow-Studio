{
  "id": "generic-group-by",
  "label": "分组聚合/Group By",
  "description": "按指定字段分组后对数值字段执行聚合运算",
  "category": "通用 · 聚合",
  "kind": "generic",
  "properties": [
    {
      "name": "groupByField",
      "label": "分组字段",
      "type": "string",
      "default": "",
      "required": true,
      "description": "用于分组的列名"
    },
    {
      "name": "aggField",
      "label": "聚合字段",
      "type": "string",
      "default": "",
      "required": true,
      "description": "要聚合的数值列名"
    },
    {
      "name": "aggFunc",
      "label": "聚合函数",
      "type": "enum",
      "enum": [
        "sum",
        "avg",
        "count",
        "min",
        "max",
        "median",
        "std"
      ],
      "default": "sum",
      "description": "聚合运算"
    }
  ],
  "ports": [
    {
      "name": "data",
      "label": "数据",
      "type": "json-rows",
      "direction": "input",
      "required": true,
      "description": "输入数据"
    },
    {
      "name": "data",
      "label": "结果",
      "type": "json-rows",
      "direction": "output",
      "description": "聚合结果"
    }
  ],
  "keywords": [
    "分组",
    "聚合",
    "group",
    "aggregate",
    "sum",
    "avg",
    "count"
  ]
}