{
  "id": "generic-handle-missing",
  "label": "空值处理/Handle Missing",
  "description": "处理缺失值：填充/前向/后向/插值/删除",
  "category": "通用 · 清洗",
  "kind": "generic",
  "properties": [
    { "name": "field", "label": "目标字段", "type": "string", "default": "", "description": "要处理的列名，留空处理所有列" },
    { "name": "strategy", "label": "策略", "type": "enum", "enum": ["fill", "forward", "backward", "interpolate", "drop_row", "drop_col"], "default": "fill", "description": "处理策略" },
    { "name": "fillValue", "label": "填充值", "type": "string", "default": "", "description": "填充策略的值" },
    { "name": "interpolateMethod", "label": "插值方法", "type": "enum", "enum": ["linear", "quadratic", "cubic"], "default": "linear", "description": "插值算法" }
  ],
  "ports": [
    { "name": "data", "label": "数据", "type": "json-rows", "direction": "input", "required": true, "description": "输入数据" },
    { "name": "data", "label": "结果", "type": "json-rows", "direction": "output", "description": "处理后数据" },
    { "name": "removedCount", "label": "处理数", "type": "number", "direction": "output", "description": "处理的行/列数" }
  ]
}
