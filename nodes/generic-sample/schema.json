{
  "id": "generic-sample",
  "label": "采样/Sample",
  "description": "随机采样或按比例采样",
  "category": "通用 · 聚合",
  "kind": "generic",
  "properties": [
    { "name": "mode", "label": "采样模式", "type": "enum", "enum": ["count", "percent"], "default": "count", "description": "按数量或按比例" },
    { "name": "count", "label": "采样数量", "type": "number", "default": 10, "min": 1, "description": "采样的行数" },
    { "name": "percent", "label": "采样比例", "type": "number", "default": 10, "min": 1, "max": 100, "description": "采样百分比" },
    { "name": "seed", "label": "随机种子", "type": "number", "default": 0, "description": "随机种子，0 为随机" }
  ],
  "ports": [
    { "name": "data", "label": "数据", "type": "json-rows", "direction": "input", "required": true, "description": "输入数据" },
    { "name": "data", "label": "结果", "type": "json-rows", "direction": "output", "description": "采样结果" },
    { "name": "rowCount", "label": "行数", "type": "number", "direction": "output", "description": "采样行数" }
  ]
}
