{
  "id": "generic-unique-check",
  "label": "唯一性检查/Unique Check",
  "description": "检查指定列值的唯一性",
  "category": "通用 · 校验",
  "kind": "generic",
  "properties": [
    { "name": "field", "label": "检查字段", "type": "string", "default": "", "required": true, "description": "要检查唯一性的列名" },
    { "name": "caseSensitive", "label": "区分大小写", "type": "boolean", "default": true, "description": "是否区分大小写" }
  ],
  "ports": [
    { "name": "data", "label": "数据", "type": "json-rows", "direction": "input", "required": true, "description": "输入数据" },
    { "name": "isUnique", "label": "是否唯一", "type": "boolean", "direction": "output", "description": "是否全部唯一" },
    { "name": "duplicates", "label": "重复行", "type": "json-rows", "direction": "output", "description": "重复的数据行" },
    { "name": "duplicateCount", "label": "重复数", "type": "number", "direction": "output", "description": "重复行数" }
  ]
}
