{
  "id": "func-form-submit",
  "label": "表单提交",
  "description": "提交表单数据，生成变更记录",
  "category": "功能 · 表单操作",
  "kind": "generic",
  "methods": [],
  "properties": [
    { "name": "validateFirst", "label": "先校验", "type": "boolean", "default": true, "description": "提交前是否先校验" },
    { "name": "exportFormat", "label": "导出格式", "type": "enum", "enum": ["changeLog", "excel", "csv", "json"], "default": "changeLog", "description": "导出格式" }
  ],
  "inputs": [
    { "name": "trigger", "type": "trigger", "required": true, "description": "触发信号" },
    { "name": "formData", "type": "object", "required": true, "description": "表单数据" },
    { "name": "originalData", "type": "object", "required": false, "description": "原始数据" }
  ],
  "outputs": [
    { "name": "success", "type": "trigger", "description": "成功" },
    { "name": "error", "type": "trigger", "description": "失败" },
    { "name": "changeLog", "type": "object", "description": "变更记录" },
    { "name": "fileData", "type": "any", "description": "文件数据" }
  ],
  "ports": [
    { "name": "trigger", "label": "触发", "type": "any", "direction": "input", "required": true, "description": "触发" },
    { "name": "formData", "label": "表单", "type": "object", "direction": "input", "required": true, "description": "表单数据" },
    { "name": "originalData", "label": "原始", "type": "object", "direction": "input", "description": "原始数据" },
    { "name": "success", "label": "成功", "type": "any", "direction": "output", "description": "成功" },
    { "name": "error", "label": "失败", "type": "any", "direction": "output", "description": "失败" },
    { "name": "changeLog", "label": "变更", "type": "object", "direction": "output", "description": "变更记录" }
  ]
}
