{
  "id": "generic-export-csv",
  "label": "导出 CSV",
  "description": "将数据导出为 CSV 文件",
  "category": "通用 · 导出",
  "kind": "generic",
  "methods": [],
  "properties": [
    {
      "name": "fileName",
      "label": "文件名",
      "type": "string",
      "default": "export.csv",
      "description": "导出的文件名"
    },
    {
      "name": "delimiter",
      "label": "分隔符",
      "type": "enum",
      "enum": [
        ",",
        ";",
        "\t",
        "|"
      ],
      "default": ",",
      "description": "字段分隔符"
    },
    {
      "name": "encoding",
      "label": "编码",
      "type": "enum",
      "enum": [
        "utf-8",
        "utf-8-bom",
        "gbk",
        "gb2312"
      ],
      "default": "utf-8-bom",
      "description": "文件编码"
    },
    {
      "name": "autoDownload",
      "label": "自动下载",
      "type": "boolean",
      "default": true,
      "description": "是否自动触发浏览器下载"
    },
    {
      "name": "includeHeader",
      "label": "包含表头",
      "type": "boolean",
      "default": true,
      "description": "是否在首行包含表头"
    }
  ],
  "inputs": [
    {
      "name": "data",
      "type": "json-rows",
      "required": true,
      "description": "要导出的数据"
    },
    {
      "name": "fileName",
      "type": "string",
      "required": false,
      "description": "文件名覆盖"
    }
  ],
  "outputs": [
    {
      "name": "csvText",
      "type": "csv-string",
      "description": "生成的 CSV 文本"
    },
    {
      "name": "fileName",
      "type": "string",
      "description": "实际使用的文件名"
    },
    {
      "name": "size",
      "type": "number",
      "description": "文件大小"
    }
  ],
  "ports": [
    {
      "name": "data",
      "label": "数据",
      "type": "json-rows",
      "direction": "input",
      "required": true,
      "description": "JSON 行数组"
    },
    {
      "name": "fileName",
      "label": "文件名",
      "type": "string",
      "direction": "input",
      "description": "文件名覆盖"
    },
    {
      "name": "csvText",
      "label": "CSV 文本",
      "type": "csv-string",
      "direction": "output",
      "description": "CSV 文本"
    },
    {
      "name": "fileName",
      "label": "文件名",
      "type": "string",
      "direction": "output",
      "description": "实际文件名"
    },
    {
      "name": "size",
      "label": "大小",
      "type": "number",
      "direction": "output",
      "description": "文件大小"
    }
  ],
  "keywords": [
    "导出",
    "csv",
    "下载",
    "export",
    "download"
  ]
}