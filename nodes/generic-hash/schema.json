    {
      "name": "newField",
      "label": "新字段名",
      "type": "string",
      "default": "hash",
      "description": "哈希值列名"
    }
  ],
  "ports": [
    {
      "name": "data",
      "label": "数据",
      "type": "json-rows",
      "direction": "input",
      "required": true,
      "description": "输入数据"
    },
    {
      "name": "data",
      "label": "结果",
      "type": "json-rows",
      "direction": "output",
      "description": "哈希后数据"
    }
  ],
  "keywords": [
    "哈希",
    "加密",
    "hash",
    "md5",
    "sha"
  ]
}