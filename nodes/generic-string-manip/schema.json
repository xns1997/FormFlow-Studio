{
  "id": "generic-string-manip",
  "label": "字符串处理/String Manipulation",
  "description": "trim/lower/upper/replace/extract/concat/split 等字符串操作",
  "category": "通用 · 清洗",
  "kind": "generic",
  "properties": [
    { "name": "field", "label": "目标字段", "type": "string", "default": "", "required": true, "description": "要处理的列名" },
    { "name": "operation", "label": "操作", "type": "enum", "enum": ["trim", "lower", "upper", "replace", "extract", "concat", "split", "pad_left", "pad_right", "substring"], "default": "trim", "description": "字符串操作" },
    { "name": "param1", "label": "参数1", "type": "string", "default": "", "description": "操作参数（如搜索词、分隔符）" },
    { "name": "param2", "label": "参数2", "type": "string", "default": "", "description": "操作参数（如替换词）" },
    { "name": "newField", "label": "新字段名", "type": "string", "default": "", "description": "结果存储到新列，留空覆盖原列" }
  ],
  "ports": [
    { "name": "data", "label": "数据", "type": "json-rows", "direction": "input", "required": true, "description": "输入数据" },
    { "name": "data", "label": "结果", "type": "json-rows", "direction": "output", "description": "处理后数据" }
  ]
}
