{
  "id": "generic-output-display",
  "label": "输出/显示",
  "description": "接收输入值并显示，可输出到下游节点或控制台",
  "category": "通用 · 输出",
  "kind": "generic",
  "methods": [],
  "properties": [
    {
      "name": "label",
      "label": "显示标签",
      "type": "string",
      "default": "输出",
      "description": "显示标签文本"
    },
    {
      "name": "format",
      "label": "显示格式",
      "type": "enum",
      "enum": ["auto", "json", "text", "table"],
      "default": "auto",
      "description": "值的显示格式"
    },
    {
