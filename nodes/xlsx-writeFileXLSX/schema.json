{
  "id": "xlsx-writeFileXLSX",
  "label": "XLSX.writeFileXLSX",
  "description": "将工作簿写出为 .xlsx 格式文件",
  "category": "XLSX · 工作簿 IO",
  "kind": "xlsx-method",
  "namespace": "XLSX",
  "methodPath": ["writeFileXLSX"],
  "inputs": [
    { "name": "workbook", "type": "Workbook", "required": true, "description": "工作簿对象" },
    { "name": "filename", "type": "string", "required": true, "description": "输出文件名" }
  ],
  "outputs": [
    { "name": "result", "type": "void", "description": "写出完成" }
  ],
  "properties": [
    { "name": "type", "label": "输出类型", "type": "enum", "enum": ["array", "buffer", "binary", "base64"], "default": "array", "description": "中间序列化格式" },
    { "name": "compression", "label": "压缩", "type": "boolean", "default": false, "description": "是否启用 ZIP 压缩" }
  ]
