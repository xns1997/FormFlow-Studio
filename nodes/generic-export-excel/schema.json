{
  "id": "generic-export-excel",
  "label": "导出 Excel",
  "description": "将数据导出为 Excel 文件，支持下载或传递",
  "category": "通用 · 导出",
  "kind": "generic",
  "methods": [],
  "properties": [
    {
      "name": "fileName",
      "label": "文件名",
      "type": "string",
      "default": "export.xlsx",
      "description": "导出的文件名"
    },
    {
      "name": "sheetName",
      "label": "工作表名",
      "type": "string",
      "default": "Sheet1",
      "description": "工作表名称"
    },
    {
      "name": "autoDownload",
      "label": "自动下载",
      "type": "boolean",
      "default": true,
      "description": "是否自动触发浏览器下载"
    },
    {
      "name": "includeHeader",
      "label": "包含表头",
      "type": "boolean",
      "default": true,
      "description": "是否在首行包含表头"
    }
  ],
  "inputs": [
    { "name": "data", "type": "json-rows", "required": true, "description": "要导出的数据 (JSON 行数组)" },
    { "name": "fileName", "type": "string", "required": false, "description": "文件名覆盖" }
  ],
  "outputs": [
    { "name": "fileData", "type": "file-data", "description": "生成的 Excel 文件数据" },
    { "name": "fileName", "type": "string", "description": "实际使用的文件名" },
    { "name": "size", "type": "number", "description": "文件大小 (字节)" }
  ],
  "ports": [
    { "name": "data", "label": "数据", "type": "json-rows", "direction": "input", "required": true, "description": "JSON 行数组" },
    { "name": "fileName", "label": "文件名", "type": "string", "direction": "input", "description": "文件名覆盖" },
    { "name": "fileData", "label": "文件数据", "type": "file-data", "direction": "output", "description": "Excel 文件数据" },
    { "name": "fileName", "label": "文件名", "type": "string", "direction": "output", "description": "实际文件名" },
    { "name": "size", "label": "大小", "type": "number", "direction": "output", "description": "文件大小" }
  ]
}
