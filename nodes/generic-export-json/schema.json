{
  "id": "generic-export-json",
  "label": "导出 JSON",
  "description": "将数据导出为 JSON 文件",
  "category": "通用 · 导出",
  "kind": "generic",
  "methods": [],
  "properties": [
    {
      "name": "fileName",
      "label": "文件名",
      "type": "string",
      "default": "export.json",
      "description": "导出的文件名"
    },
    {
      "name": "pretty",
      "label": "格式化",
      "type": "boolean",
      "default": true,
      "description": "是否格式化 JSON"
    },
    {
      "name": "indent",
      "label": "缩进",
      "type": "number",
      "default": 2,
      "min": 0,
      "max": 8,
      "description": "缩进空格数"
    },
    {
      "name": "autoDownload",
      "label": "自动下载",
      "type": "boolean",
      "default": true,
      "description": "是否自动触发浏览器下载"
    },
    {
      "name": "rootKey",
      "label": "根键名",
      "type": "string",
      "default": "",
      "description": "包装数据的根键名，留空则直接输出数组"
    }
  ],
  "inputs": [
    { "name": "data", "type": "any", "required": true, "description": "要导出的数据" },
    { "name": "fileName", "type": "string", "required": false, "description": "文件名覆盖" }
  ],
  "outputs": [
    { "name": "jsonText", "type": "json-string", "description": "生成的 JSON 文本" },
    { "name": "fileName", "type": "string", "description": "实际使用的文件名" },
    { "name": "size", "type": "number", "description": "文件大小" }
  ],
  "ports": [
    { "name": "data", "label": "数据", "type": "any", "direction": "input", "required": true, "description": "要导出的数据" },
    { "name": "fileName", "label": "文件名", "type": "string", "direction": "input", "description": "文件名覆盖" },
    { "name": "jsonText", "label": "JSON 文本", "type": "json-string", "direction": "output", "description": "JSON 文本" },
    { "name": "fileName", "label": "文件名", "type": "string", "direction": "output", "description": "实际文件名" },
    { "name": "size", "label": "大小", "type": "number", "direction": "output", "description": "文件大小" }
  ]
}
