{
  "id": "form:save", "label": "表单保存", "description": "一次完成必填校验、字段映射、按主键写回和成功提示", "category": "高阶 · 表单", "kind": "generic", "macro": { "version": 1, "expansion": "runtime-composite", "debugMapping": "node-output", "snapshot": [] },
  "properties": [
