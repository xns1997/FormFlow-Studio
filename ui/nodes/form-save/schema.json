    { "name": "status", "label": "保存状态", "type": "string", "direction": "output" },
    { "name": "row", "label": "写入记录", "type": "object", "direction": "output" },
    { "name": "missingFields", "label": "缺失字段", "type": "array", "direction": "output" },
