    { "name": "sheetName", "label": "工作表", "type": "string", "default": "" },
    { "name": "keyField", "label": "主键字段", "type": "string", "default": "" },
    { "name": "requiredFields", "label": "必填字段", "type": "array", "default": [] },
    { "name": "fieldMap", "label": "字段映射", "type": "json", "default": {} },
    { "name": "rules", "label": "字段规则", "type": "json", "default": {} },
    { "name": "conditionalRequired", "label": "条件必填", "type": "json", "default": [] },
    { "name": "foreignKeys", "label": "外键校验", "type": "json", "default": [] },
    { "name": "duplicatePolicy", "label": "重复主键策略", "type": "select", "default": "upsert", "options": [{ "label": "新增或更新", "value": "upsert" }, { "label": "拒绝重复", "value": "reject" }] },
    { "name": "protectedUpdate", "label": "受保护更新", "type": "json", "default": {} },
    { "name": "deriveFirstPurchase", "label": "计算首充标记", "type": "boolean", "default": false },
    { "name": "successMessage", "label": "成功提示", "type": "string", "default": "保存成功" },
