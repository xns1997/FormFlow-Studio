{
  "id": "generic-encode",
  "label": "编码转换/Encode",
  "description": "Base64/URL/HTML 实体编解码",
  "category": "通用 · 清洗",
  "kind": "generic",
  "properties": [
    {
      "name": "field",
      "label": "目标字段",
      "type": "string",
      "default": "",
      "required": true,
      "description": "要编码的列名"
    },
    {
      "name": "encoding",
      "label": "编码方式",
      "type": "enum",
      "enum": [
        "base64_encode",
        "base64_decode",
        "url_encode",
        "url_decode",
        "html_escape",
        "html_unescape"
      ],
      "default": "base64_encode",
      "description": "编解码方式"
    },
    {
      "name": "newField",
      "label": "新字段名",
      "type": "string",
      "default": "",
      "description": "结果列名，留空覆盖原列"
    }
  ],
  "ports": [
    {
      "name": "data",
      "label": "数据",
      "type": "json-rows",
      "direction": "input",
      "required": true,
      "description": "输入数据"
    },
    {
      "name": "data",
      "label": "结果",
      "type": "json-rows",
      "direction": "output",
      "description": "编码后数据"
    }
  ],
  "keywords": [
    "编码",
    "解码",
    "encode",
    "decode",
    "base64",
    "url"
  ]
}