{
  "id": "behavior:submit",
  "label": "提交数据",
  "description": "将表单数据提交（生成变更记录）",
  "category": "行为 · 动作",
  "kind": "generic",
  "methods": [],
  "properties": [
    {
      "name": "validateFirst",
      "label": "先校验",
      "type": "boolean",
      "default": true,
      "description": "提交前是否先校验"
    },
    {
      "name": "target",
      "label": "提交目标",
      "type": "enum",
      "enum": [
        "changeLog",
        "newExcel",
        "csv",
        "json"
      ],
      "default": "changeLog",
      "description": "提交输出格式"
    },
    {
      "name": "fileName",
      "label": "文件名",
      "type": "string",
      "default": "output",
      "description": "输出文件名（不含扩展名）"
    },
    {
      "name": "writeBackMode",
      "label": "元数据写回",
      "type": "enum",
      "enum": ["none", "upsert"],
      "default": "none",
      "description": "按主键更新或新增项目数据表行"
    },
    {
      "name": "writeBackTableId",
      "label": "目标数据表 ID",
      "type": "string",
      "default": ""
    },
    {
      "name": "writeBackSheetName",
      "label": "目标工作表",
      "type": "string",
      "default": ""
    },
    {
      "name": "writeBackKeyField",
      "label": "主键列",
      "type": "string",
      "default": ""
    },
    {
      "name": "writeBackKeyFormField",
      "label": "主键表单字段",
      "type": "string",
      "default": ""
    },
    {
      "name": "writeBackFieldMap",
      "label": "字段映射",
      "type": "json",
      "default": {},
      "description": "表单字段名到数据表列名的映射"
    }
  ],
  "inputs": [
    {
      "name": "trigger",
      "type": "trigger",
      "required": false,
      "description": "触发信号"
    },
    {
      "name": "formData",
      "type": "object",
      "required": true,
      "description": "表单数据"
    },
    {
      "name": "originalData",
      "type": "object",
      "required": false,
      "description": "原始数据"
    }
  ],
  "outputs": [
    {
      "name": "success",
      "type": "trigger",
      "description": "成功触发"
    },
    {
      "name": "error",
      "type": "trigger",
      "description": "失败触发"
    },
    {
      "name": "changeLog",
      "type": "object",
      "description": "变更记录"
    },
    {
      "name": "fileData",
      "type": "any",
      "description": "输出文件数据"
    },
    {
      "name": "writeBack",
      "type": "object",
      "description": "由表单运行时应用的元数据写回指令"
    }
  ],
  "ports": [
    {
      "name": "trigger",
      "label": "触发",
      "type": "any",
      "direction": "input",
      "required": false,
      "description": "触发信号"
    },
    {
      "name": "formData",
      "label": "表单数据",
      "type": "object",
      "direction": "input",
      "required": true,
      "description": "表单数据"
    },
    {
      "name": "originalData",
      "label": "原始数据",
      "type": "object",
      "direction": "input",
      "description": "原始数据"
    },
    {
      "name": "success",
      "label": "成功",
      "type": "any",
      "direction": "output",
      "description": "提交成功"
    },
    {
      "name": "error",
      "label": "失败",
      "type": "any",
      "direction": "output",
      "description": "提交失败"
    },
    {
      "name": "changeLog",
      "label": "变更记录",
      "type": "object",
      "direction": "output",
      "description": "变更记录"
    },
    {
      "name": "fileData",
      "label": "文件数据",
      "type": "any",
      "direction": "output",
      "description": "文件数据"
    },
    {
      "name": "writeBack",
      "label": "元数据写回",
      "type": "object",
      "direction": "output",
      "description": "受控的数据表行更新指令"
    }
  ],
  "keywords": [
    "提交",
    "submit"
  ]
}
