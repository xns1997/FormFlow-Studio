    {
      "id": "example_renewable_generation_create_submit",
      "type": "button",
      "x": 24,
      "y": 368,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_renewable_generation_create_submit",
        "label": "保存录入",
        "variant": "primary",
        "events": {
          "onClick": "if (!ctx.getValue('日期') && ctx.getValue('日期') !== 0) return ctx.showMessage('请填写日期', 'error');\nif (!ctx.getValue('场站') && ctx.getValue('场站') !== 0) return ctx.showMessage('请填写场站', 'error');\nif (!ctx.getValue('发电类型') && ctx.getValue('发电类型') !== 0) return ctx.showMessage('请填写发电类型', 'error');\nif (!ctx.getValue('发电量MWh') && ctx.getValue('发电量MWh') !== 0) return ctx.showMessage('请填写发电量MWh', 'error');\nif (!ctx.getValue('资源指标') && ctx.getValue('资源指标') !== 0) return ctx.showMessage('请填写资源指标', 'error');\nif (!ctx.getValue('限电损失MWh') && ctx.getValue('限电损失MWh') !== 0) return ctx.showMessage('请填写限电损失MWh', 'error');\nif (!ctx.getValue('设备可用率') && ctx.getValue('设备可用率') !== 0) return ctx.showMessage('请填写设备可用率', 'error');\nlet currentId = Number(ctx.getValue('记录ID') || 0);\nif (!currentId) {\n  currentId = (() => { const rows = ctx.querySheet('renewable_generation');\nconst maxId = rows.reduce((max, row) => Math.max(max, Number(row?.记录ID) || 0), 0);\nreturn maxId + 1; })();\n  await ctx.setValue('记录ID', currentId);\n}\n\nawait ctx.runConfiguredWorkflow();\nconst nextId = (() => { const rows = ctx.querySheet('renewable_generation');\nconst maxId = rows.reduce((max, row) => Math.max(max, Number(row?.记录ID) || 0), 0);\nreturn maxId + 1; })();\nawait ctx.setValue('记录ID', nextId);\nawait ctx.setValue('日期', \"2026-07-06\");\nawait ctx.setValue('发电类型', \"光伏\");\nawait ctx.setValue('场站', \"青海光伏一站\");\nawait ctx.setValue('发电量MWh', '');\nawait ctx.setValue('资源指标', '');\nawait ctx.setValue('限电损失MWh', '');\nawait ctx.setValue('设备可用率', '');\nawait ctx.setValue('状态提示', '表单已重置，可继续录入。');\nawait ctx.showMessage(`新能源发电量已新增：${currentId}`, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_renewable_generation_wf_create",
            "parameterMap": {
              "submit.formData": {
                "记录ID": "$form.记录ID",
                "日期": "$form.日期",
                "场站": "$form.场站",
                "发电类型": "$form.发电类型",
                "发电量MWh": "$form.发电量MWh",
                "资源指标": "$form.资源指标",
                "限电损失MWh": "$form.限电损失MWh",
                "设备可用率": "$form.设备可用率"
              }
            }
          }
        }
      }
