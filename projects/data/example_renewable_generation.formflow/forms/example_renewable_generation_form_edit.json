    {
      "id": "example_renewable_generation_search_btn",
      "type": "button",
      "x": 264,
      "y": 116,
      "width": 180,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_renewable_generation_search_btn",
        "label": "查询记录",
        "variant": "primary",
        "events": {
          "onClick": "const filterValue = String(ctx.getValue('筛选场站') || '全部');\nconst rows = ctx.querySheet('renewable_generation').filter((row) => filterValue === '全部' || String(row?.场站 ?? '') === filterValue);\nawait ctx.setValue('example_renewable_generation_列表', rows);\nawait ctx.setValue('处理提示', `已加载 ${rows.length} 条记录`);"
        }
      }
    },
    {
      "id": "example_renewable_generation_result_table",
      "type": "table",
      "x": 24,
      "y": 196,
      "width": 520,
      "height": 260,
      "zIndex": 2,
      "fieldBinding": "example_renewable_generation_列表",
      "props": {
        "name": "example_renewable_generation_列表",
        "columns": [
          "记录ID",
          "日期",
          "场站",
          "发电类型",
          "发电量MWh",
          "资源指标",
          "设备可用率"
        ],
        "rows": 5,
        "events": {
          "onRowClick": "const row = ctx.detail?.row || {};\nawait ctx.setValue('记录ID', row.记录ID ?? '');\nawait ctx.setValue('日期', row.日期 ?? '');\nawait ctx.setValue('场站', row.场站 ?? '');\nawait ctx.setValue('发电类型', row.发电类型 ?? '');\nawait ctx.setValue('发电量MWh', row.发电量MWh ?? '');\nawait ctx.setValue('资源指标', row.资源指标 ?? '');\nawait ctx.setValue('限电损失MWh', row.限电损失MWh ?? '');\nawait ctx.setValue('设备可用率', row.设备可用率 ?? '');\nawait ctx.setValue('原始记录ID', row.记录ID ?? '');\nawait ctx.setValue('原始日期', row.日期 ?? '');\nawait ctx.setValue('原始场站', row.场站 ?? '');\nawait ctx.setValue('原始发电类型', row.发电类型 ?? '');\nawait ctx.setValue('原始发电量MWh', row.发电量MWh ?? '');\nawait ctx.setValue('原始资源指标', row.资源指标 ?? '');\nawait ctx.setValue('原始限电损失MWh', row.限电损失MWh ?? '');\nawait ctx.setValue('原始设备可用率', row.设备可用率 ?? '');\nawait ctx.setValue('处理提示', `已载入 记录ID：${row.记录ID || ''}`);"
        }
      }
    },
