    {
      "id": "example_renewable_generation_update_btn",
      "type": "button",
      "x": 568,
      "y": 564,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_renewable_generation_update_btn",
        "label": "保存修改",
        "variant": "primary",
        "events": {
          "onClick": "const id = ctx.getValue('记录ID');\nif (!id && id !== 0) return ctx.showMessage('请先从左侧表格选择记录', 'error');\n\nawait ctx.runConfiguredWorkflow();\nawait ctx.setValue('处理提示', `新能源发电量已更新：${id}`);\nawait ctx.showMessage(`新能源发电量已更新：${id}`, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_renewable_generation_wf_update",
            "parameterMap": {
              "workflow:import.formData": {
                "记录ID": "$form.记录ID",
                "日期": "$form.日期",
                "场站": "$form.场站",
                "发电类型": "$form.发电类型",
                "发电量MWh": "$form.发电量MWh",
                "资源指标": "$form.资源指标",
                "限电损失MWh": "$form.限电损失MWh",
                "设备可用率": "$form.设备可用率"
              },
              "workflow:import.originalData": {
                "记录ID": "$form.原始记录ID",
                "日期": "$form.原始日期",
                "场站": "$form.原始场站",
                "发电类型": "$form.原始发电类型",
                "发电量MWh": "$form.原始发电量MWh",
                "资源指标": "$form.原始资源指标",
                "限电损失MWh": "$form.原始限电损失MWh",
                "设备可用率": "$form.原始设备可用率"
              }
            }
          }
        }
      }
