        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({\n  rows: ctx.querySheet('renewable_generation'),\n  \"siteName\": String(ctx.getValue('统计场站') || '全部'),\n  \"days\": Number(ctx.getValue('预测天数') || 1)\n});\nconst outputs = result.nodeResults.get('workflow:export')?.outputs.result || {};\nawait ctx.setValue('预测结果', outputs.rows || []);\nawait ctx.setValue('预测摘要', outputs.summary || '');\nreturn outputs.summary || '';"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_renewable_generation_wf_predict",
