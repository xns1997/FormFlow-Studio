    {
      "id": "example_renewable_generation_stats_btn",
      "type": "button",
      "x": 664,
      "y": 116,
      "width": 120,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_renewable_generation_stats_btn",
        "label": "统计分析",
        "variant": "primary",
        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({\n  rows: ctx.querySheet('renewable_generation'),\n  \"siteName\": String(ctx.getValue('统计场站') || '全部')\n});\nconst outputs = result.nodeResults.get('workflow:export')?.outputs.result || {};\nawait ctx.setValue('统计结果', outputs.rows || []);\nawait ctx.setValue('统计摘要', outputs.summary || '');\nreturn outputs.summary || '';"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_renewable_generation_wf_stats",
            "parameterMap": {
              "workflow:import.siteName": "$form.统计场站"
            }
          }
        }
      }
    },
    {
      "id": "example_renewable_generation_batch_btn",
      "type": "button",
      "x": 804,
      "y": 116,
      "width": 120,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_renewable_generation_batch_btn",
        "label": "批量处理",
        "variant": "primary",
        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({\n  rows: ctx.querySheet('renewable_generation'),\n  \"siteName\": String(ctx.getValue('统计场站') || '全部'),\n  \"adjustRatio\": Number(ctx.getValue('修正系数') || 0)\n});\nconst outputs = result.nodeResults.get('workflow:export')?.outputs.result || {};\nawait ctx.setValue('批量结果', outputs.rows || []);\nawait ctx.setValue('批量摘要', outputs.summary || '');\nreturn outputs.summary || '';"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_renewable_generation_wf_batch",
            "parameterMap": {
              "workflow:import.siteName": "$form.统计场站",
              "workflow:import.adjustRatio": "$form.修正系数"
            }
          }
        }
      }
    },
    {
      "id": "example_renewable_generation_predict_btn",
