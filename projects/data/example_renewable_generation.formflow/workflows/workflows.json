    {
      "id": "example_renewable_generation_wf_batch",
      "name": "批量处理",
      "description": "新能源发电量 批量处理",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"siteName\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"siteName\\\",\\\"description\\\":\\\"siteName 输入\\\"},{\\\"name\\\":\\\"adjustRatio\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"adjustRatio\\\",\\\"description\\\":\\\"adjustRatio 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"siteName\":\"string\",\"adjustRatio\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst siteName = String(inputs.siteName || '全部');\\nconst adjustRatio = Number(inputs.adjustRatio || 0);\\nconst filtered = rows.filter((row) => siteName === '全部' || String(row?.场站 || '') === siteName);\\nreturn {\\n  summary: `已为 ${filtered.length} 条记录生成批量修正结果，修正系数 ${adjustRatio}% 。`,\\n  rows: filtered.map((row) => {\\n    const generation = Number(row?.发电量MWh || 0);\\n    const curtailment = Number(row?.限电损失MWh || 0);\\n    const net = Number(((generation - curtailment) * (1 + adjustRatio / 100)).toFixed(1));\\n    return {\\n      记录ID: row?.记录ID,\\n      场站: row?.场站,\\n      修正后净发电量: net,\\n      是否异常: Number(row?.设备可用率 || 0) < 96 || net < generation * 0.85 ? '是' : '否',\\n    };\\n  }),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
      "edges": [
