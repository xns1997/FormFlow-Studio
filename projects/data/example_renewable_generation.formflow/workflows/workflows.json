    {
      "id": "example_renewable_generation_wf_predict",
      "name": "预测",
      "description": "新能源发电量 预测分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"siteName\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"siteName\\\",\\\"description\\\":\\\"siteName 输入\\\"},{\\\"name\\\":\\\"days\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"days\\\",\\\"description\\\":\\\"days 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"siteName\":\"string\",\"days\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst siteName = String(inputs.siteName || '全部');\\nconst days = Math.max(1, Number(inputs.days || 1));\\nconst filtered = rows.filter((row) => siteName === '全部' || String(row?.场站 || '') === siteName);\\nconst base = filtered.length ? filtered.reduce((sum, row) => sum + Number(row?.发电量MWh || 0), 0) / filtered.length : 0;\\nconst site = siteName === '全部' ? '综合预测' : siteName;\\nreturn {\\n  summary: `已基于历史日电量生成未来 ${days} 天的场站发电预测。`,\\n  rows: Array.from({ length: days }, (_, index) => ({\\n    日期: `D+${index + 1}`,\\n    预测场站: site,\\n    预测发电量MWh: Number((base * (1 + 0.01 * (index + 1))).toFixed(1)),\\n  })),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
