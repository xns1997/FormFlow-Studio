    {
      "id": "example_renewable_generation_wf_stats",
      "name": "统计分析",
      "description": "新能源发电量 统计分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"siteName\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"siteName\\\",\\\"description\\\":\\\"siteName 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"siteName\":\"string\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst siteName = String(inputs.siteName || '全部');\\nconst filtered = siteName === '全部' ? rows : rows.filter((row) => String(row?.场站 || '') === siteName);\\nconst groups = new Map();\\nfor (const row of filtered) {\\n  const key = String(row?.场站 || '未分配');\\n  const bucket = groups.get(key) || { 场站: key, 记录数: 0, 总发电量: 0, 可用率合计: 0 };\\n  bucket.记录数 += 1;\\n  bucket.总发电量 += Number(row?.发电量MWh || 0);\\n  bucket.可用率合计 += Number(row?.设备可用率 || 0);\\n  groups.set(key, bucket);\\n}\\nreturn {\\n  summary: `共统计 ${filtered.length} 条发电记录，可用于快速比对各场站发电表现。`,\\n  rows: Array.from(groups.values()).map((item) => ({\\n    场站: item.场站,\\n    记录数: item.记录数,\\n    总发电量: Number(item.总发电量.toFixed(1)),\\n    平均可用率: item.记录数 ? Number((item.可用率合计 / item.记录数).toFixed(2)) : 0,\\n  })),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
      "edges": [
