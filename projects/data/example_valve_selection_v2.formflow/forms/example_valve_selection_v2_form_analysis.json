      "props": {
        "name": "example_valve_selection_v2_analysis_run",
        "label": "开始选型",
        "variant": "primary",
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_valve_selection_v2_wf_analyze",
            "parameterMap": {
              "workflow:import.criteria": [
                {
                  "field": "介质",
                  "operator": "==",
                  "value": "$form.介质"
                },
                {
                  "field": "适用DN",
                  "operator": "==",
                  "value": "$form.DN"
                },
                {
                  "field": "最高PN",
                  "operator": ">=",
                  "value": "$form.PN"
                },
                {
                  "field": "最高适用温度",
                  "operator": ">=",
                  "value": "$form.设计温度"
                },
                {
                  "field": "连接方式",
                  "operator": "==",
                  "value": "$form.连接方式"
                },
                {
                  "field": "阀体材质",
                  "operator": "==",
                  "value": "$form.阀体材质偏好"
                },
                {
                  "field": "预算等级",
                  "operator": "==",
                  "value": "$form.预算等级"
                },
                {
                  "field": "交期要求",
                  "operator": "==",
                  "value": "$form.交期要求"
                },
                {
                  "field": "防腐要求",
                  "operator": "==",
                  "value": "$form.防腐要求"
                }
              ]
            }
          }
        }
      }
