    {
      "id": "example_valve_selection_v2_update_btn",
      "type": "button",
      "x": 580,
      "y": 682,
      "width": 180,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_valve_selection_v2_update_btn",
        "label": "保存修改",
        "variant": "primary",
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_valve_selection_v2_wf_update_request",
            "parameterMap": {
              "workflow:import.formData": {
                "需求单号": "$form.需求单号",
                "项目名称": "$form.项目名称",
                "介质": "$form.介质",
                "DN": "$form.DN",
                "PN": "$form.PN",
                "设计温度": "$form.设计温度",
                "目标流量": "$form.目标流量",
                "连接方式": "$form.连接方式",
                "阀体材质偏好": "$form.阀体材质偏好",
                "预算等级": "$form.预算等级",
                "交期要求": "$form.交期要求",
                "防腐要求": "$form.防腐要求"
              },
              "workflow:import.originalData": {
                "需求单号": "$form.原始需求单号",
                "项目名称": "$form.原始项目名称",
                "介质": "$form.原始介质",
                "DN": "$form.原始DN",
                "PN": "$form.原始PN",
                "设计温度": "$form.原始设计温度",
                "目标流量": "$form.原始目标流量",
                "连接方式": "$form.原始连接方式",
                "阀体材质偏好": "$form.原始阀体材质偏好",
                "预算等级": "$form.原始预算等级",
                "交期要求": "$form.原始交期要求",
                "防腐要求": "$form.原始防腐要求"
              }
            }
          }
        }
      }
