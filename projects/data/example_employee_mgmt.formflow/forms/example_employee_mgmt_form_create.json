    {
      "id": "example_employee_mgmt_create_submit",
      "type": "button",
      "x": 24,
      "y": 368,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_employee_mgmt_create_submit",
        "label": "保存录入",
        "variant": "primary",
        "events": {
          "onClick": "if (!ctx.getValue('姓名') && ctx.getValue('姓名') !== 0) return ctx.showMessage('请填写姓名', 'error');\nif (!ctx.getValue('部门') && ctx.getValue('部门') !== 0) return ctx.showMessage('请填写部门', 'error');\nif (!ctx.getValue('岗位') && ctx.getValue('岗位') !== 0) return ctx.showMessage('请填写岗位', 'error');\nif (!ctx.getValue('入职日期') && ctx.getValue('入职日期') !== 0) return ctx.showMessage('请填写入职日期', 'error');\nif (!ctx.getValue('月薪') && ctx.getValue('月薪') !== 0) return ctx.showMessage('请填写月薪', 'error');\nlet currentId = Number(ctx.getValue('员工ID') || 0);\nif (!currentId) {\n  currentId = (() => { const rows = ctx.querySheet('employees');\nconst maxId = rows.reduce((max, row) => Math.max(max, Number(row?.员工ID) || 0), 0);\nreturn maxId + 1; })();\n  await ctx.setValue('员工ID', currentId);\n}\n\nawait ctx.runConfiguredWorkflow();\nconst nextId = (() => { const rows = ctx.querySheet('employees');\nconst maxId = rows.reduce((max, row) => Math.max(max, Number(row?.员工ID) || 0), 0);\nreturn maxId + 1; })();\nawait ctx.setValue('员工ID', nextId);\nawait ctx.setValue('部门', \"技术部\");\nawait ctx.setValue('入职日期', \"2026-07-06\");\nawait ctx.setValue('在职', true);\nawait ctx.setValue('姓名', '');\nawait ctx.setValue('岗位', '');\nawait ctx.setValue('月薪', '');\nawait ctx.setValue('状态提示', '表单已重置，可继续录入。');\nawait ctx.showMessage(`员工在职信息已新增：${currentId}`, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_employee_mgmt_wf_create",
            "parameterMap": {
              "workflow:import.formData": {
                "员工ID": "$form.员工ID",
                "姓名": "$form.姓名",
                "部门": "$form.部门",
                "岗位": "$form.岗位",
                "入职日期": "$form.入职日期",
                "在职": "$form.在职",
                "月薪": "$form.月薪"
              }
            }
          }
        }
      }
