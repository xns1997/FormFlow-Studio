          "onClick": "const nextId = (() => { const rows = ctx.querySheet('employees');\nconst maxId = rows.reduce((max, row) => Math.max(max, Number(row?.员工ID) || 0), 0);\nreturn maxId + 1; })();\nawait ctx.setValue('员工ID', nextId);\nawait ctx.setValue('部门', \"技术部\");\nawait ctx.setValue('入职日期', \"2026-07-06\");\nawait ctx.setValue('在职', true);\nawait ctx.setValue('姓名', '');\nawait ctx.setValue('岗位', '');\nawait ctx.setValue('月薪', '');\nawait ctx.setValue('状态提示', '表单已重置，可继续录入。');"
        }
