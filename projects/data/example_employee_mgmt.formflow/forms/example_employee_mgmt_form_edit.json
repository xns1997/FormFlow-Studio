      "width": 200,
      "height": 60,
      "zIndex": 2,
      "fieldBinding": "姓名",
      "props": {
        "name": "姓名",
        "label": "姓名",
        "required": true,
        "readonly": false,
        "placeholder": "请输入姓名"
      }
    },
    {
      "id": "example_employee_mgmt_edit_2",
      "type": "select",
      "x": 568,
      "y": 276,
      "width": 200,
      "height": 60,
      "zIndex": 2,
      "fieldBinding": "部门",
      "props": {
        "name": "部门",
        "label": "部门",
        "required": true,
        "readonly": false,
        "placeholder": "",
        "options": [
          "技术部",
          "销售部",
          "人事部",
          "财务部"
        ]
      }
    },
    {
      "id": "example_employee_mgmt_edit_3",
      "type": "input",
      "x": 788,
      "y": 276,
      "width": 200,
      "height": 60,
      "zIndex": 2,
      "fieldBinding": "岗位",
      "props": {
        "name": "岗位",
        "label": "岗位",
        "required": true,
        "readonly": false,
        "placeholder": "请输入岗位"
      }
    },
    {
      "id": "example_employee_mgmt_edit_4",
      "type": "datePicker",
      "x": 568,
      "y": 356,
      "width": 200,
      "height": 60,
      "zIndex": 2,
      "fieldBinding": "入职日期",
      "props": {
        "name": "入职日期",
        "label": "入职日期",
        "required": true,
        "readonly": false,
        "placeholder": ""
      }
    },
    {
      "id": "example_employee_mgmt_edit_5",
      "type": "switch",
      "x": 788,
      "y": 356,
      "width": 200,
      "height": 60,
      "zIndex": 2,
      "fieldBinding": "在职",
      "props": {
        "name": "在职",
        "label": "在职",
        "required": false,
        "readonly": false,
        "defaultValue": true
      }
    },
    {
      "id": "example_employee_mgmt_edit_6",
      "type": "number",
      "x": 568,
      "y": 436,
      "width": 200,
      "height": 60,
      "zIndex": 2,
      "fieldBinding": "月薪",
      "props": {
        "name": "月薪",
        "label": "月薪",
        "required": true,
        "readonly": false,
        "placeholder": "单位：元"
      }
    },
    {
      "id": "example_employee_mgmt_update_btn",
      "type": "button",
      "x": 568,
      "y": 564,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_employee_mgmt_update_btn",
        "label": "保存修改",
        "variant": "primary",
        "events": {
          "onClick": "const id = ctx.getValue('员工ID');\nif (!id && id !== 0) return ctx.showMessage('请先从左侧表格选择记录', 'error');\n\nawait ctx.runConfiguredWorkflow();\nawait ctx.setValue('处理提示', `员工在职信息已更新：${id}`);\nawait ctx.showMessage(`员工在职信息已更新：${id}`, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_employee_mgmt_wf_update",
            "parameterMap": {
              "workflow:import.formData": {
                "员工ID": "$form.员工ID",
                "姓名": "$form.姓名",
                "部门": "$form.部门",
                "岗位": "$form.岗位",
                "入职日期": "$form.入职日期",
                "在职": "$form.在职",
                "月薪": "$form.月薪"
              },
              "workflow:import.originalData": {
                "员工ID": "$form.原始员工ID",
                "姓名": "$form.原始姓名",
                "部门": "$form.原始部门",
                "岗位": "$form.原始岗位",
                "入职日期": "$form.原始入职日期",
                "在职": "$form.原始在职",
                "月薪": "$form.原始月薪"
              }
            }
          }
        }
      }
    }
  ]
