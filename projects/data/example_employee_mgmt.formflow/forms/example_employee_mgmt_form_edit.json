        "content": "处理提示",
        "fontSize": 13,
        "color": "#475569"
      }
    },
    {
      "id": "example_employee_mgmt_search_filter",
      "type": "select",
      "x": 24,
      "y": 116,
      "width": 220,
      "height": 60,
      "zIndex": 2,
      "fieldBinding": "筛选部门",
      "props": {
        "name": "筛选部门",
        "label": "筛选部门",
        "options": [
          "全部",
          "技术部",
          "销售部",
          "人事部",
          "财务部"
        ],
        "defaultValue": "全部"
      }
    },
    {
      "id": "example_employee_mgmt_search_btn",
      "type": "button",
      "x": 264,
      "y": 116,
      "width": 180,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_employee_mgmt_search_btn",
        "label": "查询记录",
        "variant": "primary",
        "events": {
          "onClick": "const filterValue = String(ctx.getValue('筛选部门') || '全部');\nconst rows = ctx.querySheet('employees').filter((row) => filterValue === '全部' || String(row?.部门 ?? '') === filterValue);\nawait ctx.setValue('example_employee_mgmt_列表', rows);\nawait ctx.setValue('处理提示', `已加载 ${rows.length} 条记录`);"
        }
      }
    },
    {
      "id": "example_employee_mgmt_result_table",
      "type": "table",
      "x": 24,
      "y": 196,
      "width": 520,
      "height": 260,
      "zIndex": 2,
      "fieldBinding": "example_employee_mgmt_列表",
      "props": {
        "name": "example_employee_mgmt_列表",
        "columns": [
          "员工ID",
          "姓名",
          "部门",
          "岗位",
          "在职",
          "月薪"
        ],
        "rows": 5,
        "events": {
          "onRowClick": "const row = ctx.detail?.row || {};\nawait ctx.setValue('员工ID', row.员工ID ?? '');\nawait ctx.setValue('姓名', row.姓名 ?? '');\nawait ctx.setValue('部门', row.部门 ?? '');\nawait ctx.setValue('岗位', row.岗位 ?? '');\nawait ctx.setValue('入职日期', row.入职日期 ?? '');\nawait ctx.setValue('在职', row.在职 ?? false);\nawait ctx.setValue('月薪', row.月薪 ?? '');\nawait ctx.setValue('原始员工ID', row.员工ID ?? '');\nawait ctx.setValue('原始姓名', row.姓名 ?? '');\nawait ctx.setValue('原始部门', row.部门 ?? '');\nawait ctx.setValue('原始岗位', row.岗位 ?? '');\nawait ctx.setValue('原始入职日期', row.入职日期 ?? '');\nawait ctx.setValue('原始在职', row.在职 ?? false);\nawait ctx.setValue('原始月薪', row.月薪 ?? '');\nawait ctx.setValue('处理提示', `已载入 员工ID：${row.员工ID || ''}`);"
        }
      }
    },
    {
      "id": "example_employee_mgmt_edit_0",
      "type": "number",
      "x": 568,
      "y": 196,
      "width": 200,
      "height": 60,
