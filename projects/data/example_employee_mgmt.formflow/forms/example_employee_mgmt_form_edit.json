      "fieldBinding": "员工ID",
      "props": {
        "name": "员工ID",
        "label": "员工ID",
        "required": false,
        "readonly": true,
        "placeholder": ""
      }
    },
    {
      "id": "example_employee_mgmt_edit_1",
