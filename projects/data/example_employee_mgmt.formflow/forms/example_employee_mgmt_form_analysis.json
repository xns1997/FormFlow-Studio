    {
      "id": "example_employee_mgmt_stats_btn",
      "type": "button",
      "x": 664,
      "y": 116,
      "width": 120,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_employee_mgmt_stats_btn",
        "label": "统计分析",
        "variant": "primary",
        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({\n  rows: ctx.querySheet('employees'),\n  \"department\": String(ctx.getValue('统计部门') || '全部')\n});\nconst outputs = result.nodeResults.get('script')?.outputs || {};\nawait ctx.setValue('统计结果', outputs.rows || []);\nawait ctx.setValue('统计摘要', outputs.summary || '');\nreturn outputs.summary || '';"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_employee_mgmt_wf_stats"
          }
        }
      }
    },
    {
      "id": "example_employee_mgmt_batch_btn",
      "type": "button",
      "x": 804,
      "y": 116,
      "width": 120,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_employee_mgmt_batch_btn",
        "label": "批量处理",
        "variant": "primary",
        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({\n  rows: ctx.querySheet('employees'),\n  \"department\": String(ctx.getValue('统计部门') || '全部'),\n  \"raisePercent\": Number(ctx.getValue('调薪百分比') || 0)\n});\nconst outputs = result.nodeResults.get('script')?.outputs || {};\nawait ctx.setValue('批量结果', outputs.rows || []);\nawait ctx.setValue('批量摘要', outputs.summary || '');\nreturn outputs.summary || '';"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_employee_mgmt_wf_batch"
          }
        }
      }
    },
    {
      "id": "example_employee_mgmt_predict_btn",
      "type": "button",
      "x": 944,
      "y": 116,
      "width": 120,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_employee_mgmt_predict_btn",
        "label": "预测",
        "variant": "primary",
        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({\n  rows: ctx.querySheet('employees'),\n  \"department\": String(ctx.getValue('统计部门') || '全部'),\n  \"months\": Number(ctx.getValue('预测月数') || 1)\n});\nconst outputs = result.nodeResults.get('script')?.outputs || {};\nawait ctx.setValue('预测结果', outputs.rows || []);\nawait ctx.setValue('预测摘要', outputs.summary || '');\nreturn outputs.summary || '';"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_employee_mgmt_wf_predict"
          }
        }
      }
