    {
      "id": "example_employee_mgmt_wf_stats",
      "name": "统计分析",
      "description": "员工在职信息 统计分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"department\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"department\\\",\\\"description\\\":\\\"department 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"department\":\"string\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst department = String(inputs.department || '全部');\\nconst filtered = department === '全部' ? rows : rows.filter((row) => String(row?.部门 || '') === department);\\nconst groups = new Map();\\nfor (const row of filtered) {\\n  const key = String(row?.部门 || '未分配');\\n  const bucket = groups.get(key) || { 部门: key, 人数: 0, 在职人数: 0, 月薪合计: 0 };\\n  bucket.人数 += 1;\\n  if (row?.在职) bucket.在职人数 += 1;\\n  bucket.月薪合计 += Number(row?.月薪 || 0);\\n  groups.set(key, bucket);\\n}\\nconst resultRows = Array.from(groups.values()).map((item) => ({\\n  部门: item.部门,\\n  人数: item.人数,\\n  在职人数: item.在职人数,\\n  平均月薪: item.人数 ? Number((item.月薪合计 / item.人数).toFixed(0)) : 0,\\n}));\\nconst totalSalary = filtered.reduce((sum, row) => sum + Number(row?.月薪 || 0), 0);\\nreturn {\\n  summary: `共 ${filtered.length} 名员工，其中在职 ${filtered.filter((row) => row?.在职).length} 人，月薪总额 ${totalSalary} 元。`,\\n  rows: resultRows,\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
