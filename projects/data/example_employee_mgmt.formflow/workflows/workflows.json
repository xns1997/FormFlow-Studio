    {
      "id": "example_employee_mgmt_wf_batch",
      "name": "批量处理",
      "description": "员工在职信息 批量处理",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"department\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"department\\\",\\\"description\\\":\\\"department 输入\\\"},{\\\"name\\\":\\\"raisePercent\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"raisePercent\\\",\\\"description\\\":\\\"raisePercent 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"department\":\"string\",\"raisePercent\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst department = String(inputs.department || '全部');\\nconst raisePercent = Number(inputs.raisePercent || 0);\\nconst filtered = rows.filter((row) => row?.在职 && (department === '全部' || String(row?.部门 || '') === department));\\nconst resultRows = filtered.map((row) => {\\n  const current = Number(row?.月薪 || 0);\\n  const next = Number((current * (1 + raisePercent / 100)).toFixed(0));\\n  return {\\n    员工ID: row?.员工ID,\\n    姓名: row?.姓名,\\n    部门: row?.部门,\\n    原月薪: current,\\n    调整后月薪: next,\\n  };\\n});\\nreturn {\\n  summary: `已为 ${resultRows.length} 名在职员工生成批量调薪预案，调薪比例 ${raisePercent}% 。`,\\n  rows: resultRows,\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
