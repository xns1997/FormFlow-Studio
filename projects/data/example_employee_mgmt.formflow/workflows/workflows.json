    {
      "id": "example_employee_mgmt_wf_predict",
      "name": "预测",
      "description": "员工在职信息 预测分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"department\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"department\\\",\\\"description\\\":\\\"department 输入\\\"},{\\\"name\\\":\\\"months\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"months\\\",\\\"description\\\":\\\"months 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"department\":\"string\",\"months\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst department = String(inputs.department || '全部');\\nconst months = Math.max(1, Number(inputs.months || 1));\\nconst filtered = rows.filter((row) => row?.在职 && (department === '全部' || String(row?.部门 || '') === department));\\nconst baseCount = filtered.length;\\nconst baseCost = filtered.reduce((sum, row) => sum + Number(row?.月薪 || 0), 0);\\nconst resultRows = Array.from({ length: months }, (_, index) => ({\\n  月份: `M+${index + 1}`,\\n  预测在职人数: baseCount + Math.max(0, Math.round(baseCount * 0.02 * (index + 1))),\\n  预测人工成本: Number((baseCost * (1 + 0.015 * (index + 1))).toFixed(0)),\\n}));\\nreturn {\\n  summary: `按当前在职规模推算未来 ${months} 个月的人力成本趋势，已输出逐月预测。`,\\n  rows: resultRows,\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
