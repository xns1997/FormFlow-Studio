    {
      "id": "shanghai_catering_pred_query",
      "type": "button",
      "x": 472,
      "y": 116,
      "width": 150,
      "height": 60,
      "zIndex": 3,
      "props": {
        "name": "query",
        "label": "查询预测",
        "variant": "primary",
        "events": {
          "onClick": "const check = await ctx.requireFields(['预测区域']);\nif (!check.valid) return;\nconst result = await ctx.runConfiguredWorkflow({ rows: ctx.querySheet('prediction_data') });\nconst outputs = result.nodeResults.get('workflow:export')?.outputs?.result || {};\nconst metrics = outputs.metrics || {};\nawait ctx.setValues({\n  '预测_月均新增': metrics['预测_月均新增'] ?? '--',\n  '预测_月均注销': metrics['预测_月均注销'] ?? '--',\n  '预测_总净增长': metrics['预测_总净增长'] ?? '--',\n  '预测_月均营业额': metrics['预测_月均营业额'] ?? '--',\n  '预测_平均置信度': metrics['预测_平均置信度'] ?? '--',\n  '预测_数据条数': metrics['预测_数据条数'] ?? 0,\n  '状态提示': outputs.summary || '未找到预测数据'\n});\nif (outputs.found === false) return ctx.showMessage('未找到预测数据', 'warning');\nawait ctx.showMessage('预测数据查询完成', 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "shanghai_catering_wf_prediction",
            "parameterMap": {
              "workflow:import.district": "$form.预测区域",
              "workflow:import.method": "$form.预测方法"
            }
          }
        }
      }
    },
