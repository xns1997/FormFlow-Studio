    {
      "id": "shanghai_catering_analysis_query",
      "type": "button",
      "x": 636,
      "y": 116,
      "width": 150,
      "height": 60,
      "zIndex": 3,
      "props": {
        "name": "query",
        "label": "查询分析",
        "variant": "primary",
        "events": {
          "onClick": "const check = await ctx.requireFields(['分析年份']);\nif (!check.valid) return;\nconst result = await ctx.runConfiguredWorkflow({ rows: ctx.querySheet('monthly_data') });\nconst outputs = result.nodeResults.get('workflow:export')?.outputs?.result || {};\nconst metrics = outputs.metrics || {};\nPrint('调试信息',metrics)\nawait ctx.setValues({\n  '统计_新增总数': metrics['统计_新增总数'] ?? '--',\n  '统计_注销总数': metrics['统计_注销总数'] ?? '--',\n  '统计_净增长': metrics['统计_净增长'] ?? '--',\n  '统计_累计企业': metrics['统计_累计企业'] ?? '--',\n  '统计_总营业额': metrics['统计_总营业额'] ?? '--',\n  '统计_月均营业额': metrics['统计_月均营业额'] ?? '--',\n  '统计_人均消费': metrics['统计_人均消费'] ?? '--',\n  '统计_外卖占比': metrics['统计_外卖占比'] ?? '--',\n  '统计_数据条数': metrics['统计_数据条数'] ?? 0,\n  '状态提示': outputs.summary || '未找到匹配的数据'\n});\nif (outputs.found === false) return ctx.showMessage('未找到匹配的数据', 'warning');\nawait ctx.showMessage('统计分析完成', 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "shanghai_catering_wf_analysis",
            "parameterMap": {
              "workflow:import.year": "$form.分析年份",
              "workflow:import.month": "$form.分析月份",
              "workflow:import.district": "$form.分析区域"
            }
          }
        }
      }
    },
