    {
      "id": "shanghai_catering_edit_query_btn",
      "type": "button",
      "x": 576,
      "y": 116,
      "width": 150,
      "height": 60,
      "zIndex": 3,
      "props": {
        "name": "query_btn",
        "label": "查询数据",
        "variant": "primary",
        "events": {
          "onClick": "const check = await ctx.requireFields(['查询年份', '查询月份', '查询区域']);\nif (!check.valid) return;\nconst rows = ctx.findRows('monthly_data', {\n  年份: Number(ctx.getValue('查询年份')),\n  月份: Number(ctx.getValue('查询月份')),\n  区域: String(ctx.getValue('查询区域') || '')\n}, { limit: 1 });\nconst row = rows[0];\nif (!row) {\n  await ctx.setValue('状态提示', '未找到匹配的数据');\n  return ctx.showMessage('未找到匹配的数据', 'warning');\n}\nawait ctx.fillForm(row, {\n  '新增企业数': '编辑_新增企业数',\n  '注销企业数': '编辑_注销企业数',\n  '营业额': '编辑_营业额',\n  '人均消费': '编辑_人均消费',\n  '从业人员数': '编辑_从业人员数',\n  '外卖占比': '编辑_外卖占比',\n  '累计企业数': '编辑_累计企业数',\n  '净增长': '编辑_净增长'\n});\nawait ctx.setValue('状态提示', `已加载 ${row['区域']} ${row['年份']}年${row['月份']}月数据`);\nawait ctx.showMessage('数据加载成功', 'success');"
        }
      }
    },
