    {
      "id": "shanghai_catering_edit_save_btn",
      "type": "button",
      "x": 24,
      "y": 416,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "save_btn",
        "label": "保存修改",
        "variant": "primary",
        "events": {
          "onClick": "const check = await ctx.requireFields(['查询年份', '查询月份', '查询区域', '编辑_新增企业数', '编辑_注销企业数', '编辑_营业额']);\nif (!check.valid) return;\nconst result = await ctx.runConfiguredWorkflow();\nconst outputs = result.nodeResults.get('workflow:export')?.outputs?.result || {};\nif (outputs.formData) await ctx.setValues({\n  '编辑_净增长': outputs.formData['净增长'],\n  '编辑_累计企业数': outputs.formData['累计企业数']\n});\nawait ctx.setValue('状态提示', outputs.message || '数据修改已保存');\nif (outputs.message) await ctx.showMessage(outputs.message, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "shanghai_catering_wf_edit",
            "parameterMap": {
              "workflow:import.formData": {
                "年份": "$form.查询年份",
                "月份": "$form.查询月份",
                "区域": "$form.查询区域",
                "新增企业数": "$form.编辑_新增企业数",
                "注销企业数": "$form.编辑_注销企业数",
                "净增长": "$form.编辑_净增长",
                "累计企业数": "$form.编辑_累计企业数",
                "营业额": "$form.编辑_营业额",
                "人均消费": "$form.编辑_人均消费",
                "从业人员数": "$form.编辑_从业人员数",
                "外卖占比": "$form.编辑_外卖占比"
              }
            }
          }
        }
      }
    }
