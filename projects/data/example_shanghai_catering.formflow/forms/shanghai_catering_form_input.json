    {
      "id": "shanghai_catering_input_submit",
      "type": "button",
      "x": 24,
      "y": 368,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "submit",
        "label": "保存录入",
        "variant": "primary",
        "events": {
          "onClick": "const check = await ctx.requireFields(['年份', '月份', '区域', '新增企业数', '注销企业数', '营业额']);\nif (!check.valid) return;\nconst result = await ctx.runConfiguredWorkflow({ originalData: ctx.querySheet('monthly_data') });\nconst outputs = result.nodeResults.get('workflow:export')?.outputs?.result || {};\nif (outputs.formData) await ctx.setValues(outputs.formData);\nawait ctx.setValue('状态提示', outputs.message || '数据已保存，可继续录入。');\nif (outputs.message) await ctx.showMessage(outputs.message, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "shanghai_catering_wf_input",
            "parameterMap": {
              "workflow:import.formData": {
                "年份": "$form.年份",
                "月份": "$form.月份",
                "区域": "$form.区域",
                "新增企业数": "$form.新增企业数",
                "注销企业数": "$form.注销企业数",
                "净增长": "$form.净增长",
                "累计企业数": "$form.累计企业数",
                "营业额": "$form.营业额",
                "人均消费": "$form.人均消费",
                "从业人员数": "$form.从业人员数",
                "外卖占比": "$form.外卖占比"
              }
            }
          }
        }
      }
    },
    {
      "id": "shanghai_catering_input_reset",
      "type": "button",
      "x": 264,
      "y": 368,
      "width": 180,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "reset",
        "label": "重置表单",
        "variant": "outline",
        "events": {
          "onClick": "await ctx.resetForm({\n  clearFields: ['月份', '区域', '新增企业数', '注销企业数', '营业额', '人均消费', '从业人员数', '外卖占比', '累计企业数', '净增长'],\n  defaults: { 年份: '2026', 状态提示: '表单已重置，请继续录入。' }\n});"
        }
      }
    }
