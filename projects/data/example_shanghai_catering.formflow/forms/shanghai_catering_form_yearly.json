    {
      "id": "shanghai_catering_yearly_query",
      "type": "button",
      "x": 472,
      "y": 116,
      "width": 150,
      "height": 60,
      "zIndex": 3,
      "props": {
        "name": "query",
        "label": "查询汇总",
        "variant": "primary",
        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({ rows: ctx.querySheet('yearly_summary') });\nconst outputs = result.nodeResults.get('workflow:export')?.outputs?.result || {};\nconst metrics = outputs.metrics || {};\nawait ctx.setValues({\n  '汇总_年度新增': metrics['汇总_年度新增'] ?? '--',\n  '汇总_年度注销': metrics['汇总_年度注销'] ?? '--',\n  '汇总_年度净增长': metrics['汇总_年度净增长'] ?? '--',\n  '汇总_年度营业额': metrics['汇总_年度营业额'] ?? '--',\n  '汇总_月均营业额': metrics['汇总_月均营业额'] ?? '--',\n  '汇总_人均消费': metrics['汇总_人均消费'] ?? '--',\n  '汇总_外卖占比': metrics['汇总_外卖占比'] ?? '--',\n  '汇总_从业人员': metrics['汇总_从业人员'] ?? '--',\n  '汇总_数据条数': metrics['汇总_数据条数'] ?? 0,\n  '状态提示': outputs.summary || '未找到汇总数据'\n});\nif (outputs.found === false) return ctx.showMessage('未找到汇总数据', 'warning');\nawait ctx.showMessage('年度汇总查询完成', 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "shanghai_catering_wf_yearly",
            "parameterMap": {
              "workflow:import.year": "$form.汇总年份",
              "workflow:import.district": "$form.汇总区域"
            }
          }
        }
      }
    },
