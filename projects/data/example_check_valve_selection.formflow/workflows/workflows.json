    {
      "id": "example_check_valve_selection_wf_stats",
      "name": "统计分析",
      "description": "止回阀选型 统计分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"medium\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"medium\\\",\\\"description\\\":\\\"medium 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"medium\":\"string\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst medium = String(inputs.medium || '全部');\\nconst filtered = medium === '全部' ? rows : rows.filter((row) => String(row?.介质 || '') === medium);\\nconst groups = new Map();\\nfor (const row of filtered) {\\n  const key = String(row?.介质 || '未分类');\\n  const bucket = groups.get(key) || { 介质: key, 申请数量: 0, 流量合计: 0, 待复核数量: 0 };\\n  bucket.申请数量 += 1;\\n  bucket.流量合计 += Number(row?.设计流量 || 0);\\n  if (String(row?.选型状态 || '') === '待复核') bucket.待复核数量 += 1;\\n  groups.set(key, bucket);\\n}\\nreturn {\\n  summary: `共统计 ${filtered.length} 条止回阀选型申请，可快速识别高风险介质和待复核任务。`,\\n  rows: Array.from(groups.values()).map((item) => ({\\n    介质: item.介质,\\n    申请数量: item.申请数量,\\n    平均流量: item.申请数量 ? Number((item.流量合计 / item.申请数量).toFixed(1)) : 0,\\n    待复核数量: item.待复核数量,\\n  })),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
