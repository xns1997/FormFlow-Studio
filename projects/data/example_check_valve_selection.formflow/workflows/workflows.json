    {
      "id": "example_check_valve_selection_wf_predict",
      "name": "预测",
      "description": "止回阀选型 预测分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"medium\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"medium\\\",\\\"description\\\":\\\"medium 输入\\\"},{\\\"name\\\":\\\"months\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"months\\\",\\\"description\\\":\\\"months 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"medium\":\"string\",\"months\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst medium = String(inputs.medium || '全部');\\nconst months = Math.max(1, Number(inputs.months || 1));\\nconst filtered = rows.filter((row) => medium === '全部' || String(row?.介质 || '') === medium);\\nconst counts = new Map();\\nfor (const row of filtered) {\\n  const key = String(row?.推荐型号 || '未定型');\\n  counts.set(key, (counts.get(key) || 0) + 1);\\n}\\nreturn {\\n  summary: `已基于历史选型记录预测未来 ${months} 个月各型号的备货需求。`,\\n  rows: Array.from(counts.entries()).map(([model, count]) => ({\\n    推荐型号: model,\\n    预计需求量: Math.max(1, Math.round(count * (1 + months * 0.2))),\\n    预测月份: `未来 ${months} 个月`,\\n  })),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
