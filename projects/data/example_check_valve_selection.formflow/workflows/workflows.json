    {
      "id": "example_check_valve_selection_wf_batch",
      "name": "批量处理",
      "description": "止回阀选型 批量处理",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"medium\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"medium\\\",\\\"description\\\":\\\"medium 输入\\\"},{\\\"name\\\":\\\"safetyMargin\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"safetyMargin\\\",\\\"description\\\":\\\"safetyMargin 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"medium\":\"string\",\"safetyMargin\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst medium = String(inputs.medium || '全部');\\nconst safetyMargin = Number(inputs.safetyMargin || 0);\\nconst filtered = rows.filter((row) => medium === '全部' || String(row?.介质 || '') === medium);\\nreturn {\\n  summary: `已对 ${filtered.length} 条选型申请生成批量复核建议，目标安全裕量 ${safetyMargin}% 。`,\\n  rows: filtered.map((row) => ({\\n    申请单号: row?.申请单号,\\n    项目名称: row?.项目名称,\\n    推荐动作: Number(row?.压力等级PN || 0) >= 25 || Number(row?.设计温度 || 0) > 180 ? '升级材质并人工复核' : `流量冗余提高至 ${safetyMargin}%`,\\n    建议状态: Number(row?.压力等级PN || 0) >= 25 || Number(row?.设计温度 || 0) > 180 ? '待复核' : '可直接通过',\\n  })),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
