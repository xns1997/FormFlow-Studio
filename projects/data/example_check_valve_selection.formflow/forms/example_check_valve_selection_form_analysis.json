      "zIndex": 3,
      "props": {
        "name": "example_check_valve_selection_stats_btn",
        "label": "统计分析",
        "variant": "primary",
        "events": {
          "onClick": "const result = await ctx.runConfiguredWorkflow({\n  rows: ctx.querySheet('valve_requests'),\n  \"medium\": String(ctx.getValue('统计介质') || '全部')\n});\nconst outputs = result.nodeResults.get('workflow:export')?.outputs.result || {};\nawait ctx.setValue('统计结果', outputs.rows || []);\nawait ctx.setValue('统计摘要', outputs.summary || '');\nreturn outputs.summary || '';"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_check_valve_selection_wf_stats",
            "parameterMap": {
              "workflow:import.medium": "$form.统计介质"
            }
          }
        }
      }
    },
