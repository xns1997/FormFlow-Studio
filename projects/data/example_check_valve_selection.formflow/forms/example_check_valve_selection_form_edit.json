      "props": {
        "name": "example_check_valve_selection_search_btn",
        "label": "查询记录",
        "variant": "primary",
        "events": {
          "onClick": "const filterValue = String(ctx.getValue('筛选状态') || '全部');\nconst rows = ctx.querySheet('valve_requests').filter((row) => filterValue === '全部' || String(row?.选型状态 ?? '') === filterValue);\nawait ctx.setValue('example_check_valve_selection_列表', rows);\nawait ctx.setValue('处理提示', `已加载 ${rows.length} 条记录`);"
        }
      }
    },
    {
      "id": "example_check_valve_selection_result_table",
      "type": "table",
      "x": 24,
      "y": 196,
      "width": 520,
      "height": 260,
      "zIndex": 2,
      "fieldBinding": "example_check_valve_selection_列表",
      "props": {
        "name": "example_check_valve_selection_列表",
        "columns": [
          "申请单号",
          "项目名称",
          "介质",
          "公称通径DN",
          "压力等级PN",
          "推荐型号",
          "选型状态"
        ],
        "rows": 5,
        "events": {
          "onRowClick": "const row = ctx.detail?.row || {};\nawait ctx.setValue('申请单号', row.申请单号 ?? '');\nawait ctx.setValue('项目名称', row.项目名称 ?? '');\nawait ctx.setValue('介质', row.介质 ?? '');\nawait ctx.setValue('公称通径DN', row.公称通径DN ?? '');\nawait ctx.setValue('压力等级PN', row.压力等级PN ?? '');\nawait ctx.setValue('设计温度', row.设计温度 ?? '');\nawait ctx.setValue('设计流量', row.设计流量 ?? '');\nawait ctx.setValue('推荐型号', row.推荐型号 ?? '');\nawait ctx.setValue('选型状态', row.选型状态 ?? '');\nawait ctx.setValue('原始申请单号', row.申请单号 ?? '');\nawait ctx.setValue('原始项目名称', row.项目名称 ?? '');\nawait ctx.setValue('原始介质', row.介质 ?? '');\nawait ctx.setValue('原始公称通径DN', row.公称通径DN ?? '');\nawait ctx.setValue('原始压力等级PN', row.压力等级PN ?? '');\nawait ctx.setValue('原始设计温度', row.设计温度 ?? '');\nawait ctx.setValue('原始设计流量', row.设计流量 ?? '');\nawait ctx.setValue('原始推荐型号', row.推荐型号 ?? '');\nawait ctx.setValue('原始选型状态', row.选型状态 ?? '');\nawait ctx.setValue('处理提示', `已载入 申请单号：${row.申请单号 || ''}`);"
        }
      }
    },
