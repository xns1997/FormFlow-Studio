    {
      "id": "example_check_valve_selection_update_btn",
      "type": "button",
      "x": 568,
      "y": 648,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_check_valve_selection_update_btn",
        "label": "保存修改",
        "variant": "primary",
        "events": {
          "onClick": "const id = ctx.getValue('申请单号');\nif (!id && id !== 0) return ctx.showMessage('请先从左侧表格选择记录', 'error');\nconst medium = String(ctx.getValue('介质') || '');\nconst dn = Number(ctx.getValue('公称通径DN') || 0);\nconst pn = Number(ctx.getValue('压力等级PN') || 0);\nconst temp = Number(ctx.getValue('设计温度') || 0);\nlet model = 'H44H-16C';\nif (medium === '蒸汽') model = 'H41H-25P';\nelse if (medium === '腐蚀液') model = 'HC41F-16P';\nelse if (medium === '油品') model = 'H41H-25C';\nawait ctx.setValue('推荐型号', `${model}-DN${dn}`);\nawait ctx.setValue('选型状态', temp > 180 || pn >= 25 ? '待复核' : '已通过');\nawait ctx.runConfiguredWorkflow();\nawait ctx.setValue('处理提示', `止回阀选型已更新：${id}`);\nawait ctx.showMessage(`止回阀选型已更新：${id}`, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_check_valve_selection_wf_update",
            "parameterMap": {
              "submit.formData": {
                "申请单号": "$form.申请单号",
                "项目名称": "$form.项目名称",
                "介质": "$form.介质",
                "公称通径DN": "$form.公称通径DN",
                "压力等级PN": "$form.压力等级PN",
                "设计温度": "$form.设计温度",
                "设计流量": "$form.设计流量",
                "推荐型号": "$form.推荐型号",
                "选型状态": "$form.选型状态"
              },
              "submit.originalData": {
                "申请单号": "$form.原始申请单号",
                "项目名称": "$form.原始项目名称",
                "介质": "$form.原始介质",
                "公称通径DN": "$form.原始公称通径DN",
                "压力等级PN": "$form.原始压力等级PN",
                "设计温度": "$form.原始设计温度",
