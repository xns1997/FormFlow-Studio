    {
      "id": "example_student_info_search_btn",
      "type": "button",
      "x": 264,
      "y": 116,
      "width": 180,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_student_info_search_btn",
        "label": "查询记录",
        "variant": "primary",
        "events": {
          "onClick": "const filterValue = String(ctx.getValue('筛选班级') || '全部');\nconst rows = ctx.querySheet('students').filter((row) => filterValue === '全部' || String(row?.班级 ?? '') === filterValue);\nawait ctx.setValue('example_student_info_列表', rows);\nawait ctx.setValue('处理提示', `已加载 ${rows.length} 条记录`);"
        }
      }
    },
    {
      "id": "example_student_info_result_table",
      "type": "table",
      "x": 24,
      "y": 196,
      "width": 520,
      "height": 260,
      "zIndex": 2,
      "fieldBinding": "example_student_info_列表",
      "props": {
        "name": "example_student_info_列表",
        "columns": [
          "学号",
          "姓名",
          "班级",
          "语文",
          "数学",
          "英语",
          "出勤率",
          "风险等级"
        ],
        "rows": 5,
        "events": {
          "onRowClick": "const row = ctx.detail?.row || {};\nawait ctx.setValue('学号', row.学号 ?? '');\nawait ctx.setValue('姓名', row.姓名 ?? '');\nawait ctx.setValue('班级', row.班级 ?? '');\nawait ctx.setValue('语文', row.语文 ?? '');\nawait ctx.setValue('数学', row.数学 ?? '');\nawait ctx.setValue('英语', row.英语 ?? '');\nawait ctx.setValue('出勤率', row.出勤率 ?? '');\nawait ctx.setValue('风险等级', row.风险等级 ?? '');\nawait ctx.setValue('原始学号', row.学号 ?? '');\nawait ctx.setValue('原始姓名', row.姓名 ?? '');\nawait ctx.setValue('原始班级', row.班级 ?? '');\nawait ctx.setValue('原始语文', row.语文 ?? '');\nawait ctx.setValue('原始数学', row.数学 ?? '');\nawait ctx.setValue('原始英语', row.英语 ?? '');\nawait ctx.setValue('原始出勤率', row.出勤率 ?? '');\nawait ctx.setValue('原始风险等级', row.风险等级 ?? '');\nawait ctx.setValue('处理提示', `已载入 学号：${row.学号 || ''}`);"
        }
      }
    },
