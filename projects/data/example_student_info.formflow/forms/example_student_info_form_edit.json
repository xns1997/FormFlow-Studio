    {
      "id": "example_student_info_update_btn",
      "type": "button",
      "x": 568,
      "y": 564,
      "width": 220,
      "height": 50,
      "zIndex": 3,
      "props": {
        "name": "example_student_info_update_btn",
        "label": "保存修改",
        "variant": "primary",
        "events": {
          "onClick": "const id = ctx.getValue('学号');\nif (!id && id !== 0) return ctx.showMessage('请先从左侧表格选择记录', 'error');\nconst total = Number(ctx.getValue('语文') || 0) + Number(ctx.getValue('数学') || 0) + Number(ctx.getValue('英语') || 0);\nconst attendance = Number(ctx.getValue('出勤率') || 0);\nconst risk = total < 240 || attendance < 90 ? '高' : total < 285 || attendance < 95 ? '中' : '低';\nawait ctx.setValue('风险等级', risk);\nawait ctx.runConfiguredWorkflow();\nawait ctx.setValue('处理提示', `学生信息已更新：${id}`);\nawait ctx.showMessage(`学生信息已更新：${id}`, 'success');"
        },
        "flowTriggers": {
          "onClick": {
            "enabled": true,
            "workflowId": "example_student_info_wf_update",
            "parameterMap": {
              "workflow:import.formData": {
                "学号": "$form.学号",
                "姓名": "$form.姓名",
                "班级": "$form.班级",
                "语文": "$form.语文",
                "数学": "$form.数学",
                "英语": "$form.英语",
                "出勤率": "$form.出勤率",
                "风险等级": "$form.风险等级"
              },
              "workflow:import.originalData": {
                "学号": "$form.原始学号",
                "姓名": "$form.原始姓名",
                "班级": "$form.原始班级",
                "语文": "$form.原始语文",
                "数学": "$form.原始数学",
                "英语": "$form.原始英语",
                "出勤率": "$form.原始出勤率",
                "风险等级": "$form.原始风险等级"
              }
            }
          }
        }
      }
    }
