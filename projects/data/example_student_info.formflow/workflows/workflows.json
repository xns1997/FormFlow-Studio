    {
      "id": "example_student_info_wf_stats",
      "name": "统计分析",
      "description": "学生信息 统计分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"className\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"className\\\",\\\"description\\\":\\\"className 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"className\":\"string\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst className = String(inputs.className || '全部');\\nconst filtered = className === '全部' ? rows : rows.filter((row) => String(row?.班级 || '') === className);\\nconst groups = new Map();\\nfor (const row of filtered) {\\n  const key = String(row?.班级 || '未分班');\\n  const total = Number(row?.语文 || 0) + Number(row?.数学 || 0) + Number(row?.英语 || 0);\\n  const bucket = groups.get(key) || { 班级: key, 人数: 0, 总分合计: 0, 高风险人数: 0 };\\n  bucket.人数 += 1;\\n  bucket.总分合计 += total;\\n  if (String(row?.风险等级 || '') === '高') bucket.高风险人数 += 1;\\n  groups.set(key, bucket);\\n}\\nreturn {\\n  summary: `共统计 ${filtered.length} 名学生，平均总分 ${filtered.length ? (filtered.reduce((sum, row) => sum + Number(row?.语文 || 0) + Number(row?.数学 || 0) + Number(row?.英语 || 0), 0) / filtered.length).toFixed(1) : 0}。`,\\n  rows: Array.from(groups.values()).map((item) => ({\\n    班级: item.班级,\\n    人数: item.人数,\\n    平均总分: item.人数 ? Number((item.总分合计 / item.人数).toFixed(1)) : 0,\\n    高风险人数: item.高风险人数,\\n  })),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
