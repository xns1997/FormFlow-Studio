    {
      "id": "example_student_info_wf_predict",
      "name": "预测",
      "description": "学生信息 预测分析",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"className\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"className\\\",\\\"description\\\":\\\"className 输入\\\"},{\\\"name\\\":\\\"weeks\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"weeks\\\",\\\"description\\\":\\\"weeks 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"className\":\"string\",\"weeks\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst className = String(inputs.className || '全部');\\nconst weeks = Math.max(1, Number(inputs.weeks || 1));\\nconst filtered = rows.filter((row) => className === '全部' || String(row?.班级 || '') === className);\\nreturn {\\n  summary: `基于当前成绩和出勤率，已预测未来 ${weeks} 周后各学生的期末总分表现。`,\\n  rows: filtered.map((row) => {\\n    const total = Number(row?.语文 || 0) + Number(row?.数学 || 0) + Number(row?.英语 || 0);\\n    const attendance = Number(row?.出勤率 || 0);\\n    const predicted = total + weeks * (attendance >= 97 ? 4 : attendance >= 93 ? 2 : -1);\\n    return {\\n      学号: row?.学号,\\n      姓名: row?.姓名,\\n      预测期末总分: predicted,\\n      风险判断: predicted < 255 ? '需重点跟踪' : predicted < 300 ? '可提升' : '稳定',\\n    };\\n  }),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
