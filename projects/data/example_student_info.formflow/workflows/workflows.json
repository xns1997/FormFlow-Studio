    {
      "id": "example_student_info_wf_batch",
      "name": "批量处理",
      "description": "学生信息 批量处理",
      "createdAt": "2026-07-06T18:00:00.000Z",
      "updatedAt": "2026-07-06T18:00:00.000Z",
      "nodes": [
        {
          "id": "workflow:import",
          "type": "formflow",
          "specId": "workflow:import",
          "position": {
            "x": 60,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"outputPorts\":\"[{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输入\\\"},{\\\"name\\\":\\\"className\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"className\\\",\\\"description\\\":\\\"className 输入\\\"},{\\\"name\\\":\\\"targetBoost\\\",\\\"type\\\":\\\"number\\\",\\\"label\\\":\\\"targetBoost\\\",\\\"description\\\":\\\"targetBoost 输入\\\"}]\"}"
          }
        },
        {
          "id": "script",
          "type": "generic",
          "specId": "behavior-js-script",
          "position": {
            "x": 360,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":{\"rows\":\"array\",\"className\":\"string\",\"targetBoost\":\"number\"},\"outputPorts\":{\"summary\":\"string\",\"rows\":\"array\"},\"script\":\"const rows = Array.isArray(inputs.rows) ? inputs.rows : [];\\nconst className = String(inputs.className || '全部');\\nconst targetBoost = Number(inputs.targetBoost || 0);\\nconst filtered = rows.filter((row) => (className === '全部' || String(row?.班级 || '') === className) && String(row?.风险等级 || '') !== '低');\\nreturn {\\n  summary: `已为 ${filtered.length} 名需要关注的学生生成批量辅导建议，目标提分 ${targetBoost} 分。`,\\n  rows: filtered.map((row) => {\\n    const total = Number(row?.语文 || 0) + Number(row?.数学 || 0) + Number(row?.英语 || 0);\\n    return {\\n      学号: row?.学号,\\n      姓名: row?.姓名,\\n      当前总分: total,\\n      辅导建议: total < 240 ? `安排一对一辅导，目标 +${targetBoost}` : `安排周测跟踪，目标 +${Math.max(6, Math.round(targetBoost / 2))}`,\\n    };\\n  }),\\n};\"}"
          }
        },
        {
          "id": "workflow:export",
          "type": "formflow",
          "specId": "workflow:export",
          "position": {
            "x": 680,
            "y": 180
          },
          "data": {
            "propertiesJson": "{\"inputPorts\":\"[{\\\"name\\\":\\\"summary\\\",\\\"type\\\":\\\"string\\\",\\\"label\\\":\\\"summary\\\",\\\"description\\\":\\\"summary 输出\\\"},{\\\"name\\\":\\\"rows\\\",\\\"type\\\":\\\"array\\\",\\\"label\\\":\\\"rows\\\",\\\"description\\\":\\\"rows 输出\\\"}]\"}"
          }
        }
      ],
