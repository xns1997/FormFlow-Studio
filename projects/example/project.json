  "behaviors": [
    {
      "id": "bh_salary_calc",
      "name": "薪资计算脚本",
      "event": "onFieldChange",
      "code": "// 当薪资或绩效变化时自动计算奖金\nconst salary = ctx.getValue('薪资') || 0;\nconst perf = ctx.getValue('绩效评分') || 0;\nconst bonus = perf >= 90 ? salary * 0.2 : salary * 0.1;\nctx.setValue('奖金', Math.round(bonus * 100) / 100);\nctx.setValue('总薪酬', Math.round((salary + bonus) * 100) / 100);\nctx.showMessage('奖金已计算: ' + bonus, 'info');",
      "priority": 1,
      "enabled": true,
      "createdAt": "2026-06-29T00:00:00.000Z",
      "updatedAt": "2026-06-29T00:00:00.000Z"
    }
  ],
