  "designs": [
    {
      "id": "design_product_lookup_edit",
      "name": "商品查询修改表单",
      "createdAt": "2026-07-02T12:00:00.000Z",
      "updatedAt": "2026-07-02T12:00:00.000Z",
      "viewport": {
        "zoom": 1,
        "panX": 0,
        "panY": 0
      },
      "components": [
        {
          "id": "form_root",
          "type": "form",
          "x": 40,
          "y": 40,
          "width": 980,
          "height": 760,
          "zIndex": 0,
          "children": [
            "lookup_id",
            "lookup_name",
            "button_find_product",
            "product_id",
            "product_name",
            "product_category",
            "product_price",
            "product_status",
            "button_save_product",
            "hidden_loaded_product_id",
            "hidden_original_product_id",
            "hidden_original_product_name",
            "hidden_original_product_category",
            "hidden_original_product_price",
            "hidden_original_product_status"
          ],
          "props": {
            "title": "商品资料查找与修改",
            "subtitle": "先按商品编号和商品名称定位商品，再修改名称、分类、价格或状态并保存回原表。",
            "background": "#f2f2f7",
            "padding": 20,
            "showFooter": false
          }
        },
        {
          "id": "lookup_id",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 150,
          "width": 280,
          "height": 72,
          "zIndex": 2,
          "props": {
            "label": "商品编号",
            "name": "lookupProductId",
            "placeholder": "例如 P-1001",
            "events": {
              "onChange": "await ctx.setValue('loadedProductId', ''); await ctx.setDisabled('button_save_product', true);"
            }
          }
        },
        {
          "id": "lookup_name",
          "type": "input",
          "parentId": "form_root",
          "x": 400,
          "y": 150,
          "width": 280,
          "height": 72,
          "zIndex": 2,
          "props": {
            "label": "商品名称",
            "name": "lookupProductName",
            "placeholder": "例如 无线鼠标",
            "events": {
              "onChange": "await ctx.setValue('loadedProductId', ''); await ctx.setDisabled('button_save_product', true);"
            }
          }
        },
        {
          "id": "button_find_product",
          "type": "button",
          "parentId": "form_root",
          "x": 700,
          "y": 164,
          "width": 180,
          "height": 52,
          "zIndex": 2,
          "props": {
            "label": "查找商品",
            "name": "findProduct",
            "icon": "🔍",
            "flowTriggers": {
              "onClick": {
                "enabled": true,
                "workflowId": "wf_product_lookup",
                "parameterMap": {
                  "lookup.filter": {
                    "商品编号": "$form.lookupProductId",
                    "商品名称": "$form.lookupProductName"
                  }
                }
              }
            }
          }
        },
        {
          "id": "product_id",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 300,
          "width": 280,
          "height": 72,
          "zIndex": 2,
          "props": {
            "label": "商品编号",
            "name": "productId",
            "readonly": true,
            "placeholder": "查找成功后自动回填"
          }
        },
        {
          "id": "product_category",
          "type": "select",
          "parentId": "form_root",
          "x": 400,
          "y": 300,
          "width": 280,
          "height": 72,
          "zIndex": 2,
          "props": {
            "label": "商品分类",
            "name": "productCategory",
            "placeholder": "请选择分类",
            "options": [
              "外设",
              "显示设备",
              "配件"
            ]
          }
        },
        {
          "id": "product_name",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 390,
          "width": 280,
          "height": 72,
          "zIndex": 2,
          "props": {
            "label": "商品名称",
            "name": "productName",
            "required": true,
            "placeholder": "查找成功后可修改"
          }
        },
        {
          "id": "product_price",
          "type": "number",
          "parentId": "form_root",
          "x": 400,
          "y": 390,
          "width": 280,
          "height": 72,
          "zIndex": 2,
          "props": {
            "label": "价格",
            "name": "productPrice",
            "required": true,
            "placeholder": "请输入价格",
            "min": 0,
            "step": 1
          }
        },
        {
          "id": "product_status",
          "type": "select",
          "parentId": "form_root",
          "x": 100,
          "y": 480,
          "width": 280,
          "height": 72,
          "zIndex": 2,
          "props": {
            "label": "状态",
            "name": "productStatus",
            "placeholder": "请选择状态",
            "options": [
              "上架",
              "下架"
            ]
          }
        },
        {
          "id": "button_save_product",
          "type": "button",
          "parentId": "form_root",
          "x": 700,
          "y": 500,
          "width": 180,
          "height": 52,
          "zIndex": 2,
          "props": {
            "label": "保存修改",
            "name": "saveProduct",
            "disabled": true,
            "icon": "💾",
            "events": {
              "onClick": "if (!ctx.getValue('loadedProductId') || ctx.getValue('loadedProductId') !== ctx.getValue('productId')) { throw new Error('请先查找到商品'); }"
            },
            "flowTriggers": {
              "onClick": {
                "enabled": true,
                "workflowId": "wf_product_save",
                "parameterMap": {
                  "submit.formData": {
                    "productId": "$form.productId",
                    "productName": "$form.productName",
                    "productCategory": "$form.productCategory",
                    "productPrice": "$form.productPrice",
                    "productStatus": "$form.productStatus"
                  },
                  "submit.originalData": {
                    "productId": "$form.originalProductId",
                    "productName": "$form.originalProductName",
                    "productCategory": "$form.originalProductCategory",
                    "productPrice": "$form.originalProductPrice",
                    "productStatus": "$form.originalProductStatus"
                  },
                  "submit.trigger": "$event"
                }
              }
            }
          }
        },
        {
          "id": "hidden_loaded_product_id",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 620,
          "width": 220,
          "height": 60,
          "zIndex": 1,
          "visible": false,
          "props": {
            "label": "loadedProductId",
            "name": "loadedProductId",
            "readonly": true
          }
        },
        {
          "id": "hidden_original_product_id",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 620,
          "width": 220,
          "height": 60,
          "zIndex": 1,
          "visible": false,
          "props": {
            "label": "originalProductId",
            "name": "originalProductId",
            "readonly": true
          }
        },
        {
          "id": "hidden_original_product_name",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 620,
          "width": 220,
          "height": 60,
          "zIndex": 1,
          "visible": false,
          "props": {
            "label": "originalProductName",
            "name": "originalProductName",
            "readonly": true
          }
        },
        {
          "id": "hidden_original_product_category",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 620,
          "width": 220,
          "height": 60,
          "zIndex": 1,
          "visible": false,
          "props": {
            "label": "originalProductCategory",
            "name": "originalProductCategory",
            "readonly": true
          }
        },
        {
          "id": "hidden_original_product_price",
          "type": "number",
          "parentId": "form_root",
          "x": 100,
          "y": 620,
          "width": 220,
          "height": 60,
          "zIndex": 1,
          "visible": false,
          "props": {
            "label": "originalProductPrice",
            "name": "originalProductPrice",
            "readonly": true
          }
        },
        {
          "id": "hidden_original_product_status",
          "type": "input",
          "parentId": "form_root",
          "x": 100,
          "y": 620,
          "width": 220,
          "height": 60,
          "zIndex": 1,
          "visible": false,
          "props": {
            "label": "originalProductStatus",
            "name": "originalProductStatus",
            "readonly": true
          }
        }
      ]
    }
  ]
