      "nodes": [
        {
          "id": "lookup",
          "specId": "behavior-row-lookup",
          "type": "formflow",
          "position": {
            "x": 240,
            "y": 160
          },
          "data": {
            "specId": "behavior-row-lookup",
            "connectedPortsJson": "[]",
            "propertiesJson": "{\"tableId\":\"product_catalog\",\"sheetName\":\"商品档案\",\"loadedFieldName\":\"loadedProductId\",\"loadedColumn\":\"商品编号\",\"enableComponentId\":\"button_save_product\",\"fieldMap\":{\"商品编号\":\"productId\",\"商品名称\":\"productName\",\"商品分类\":\"productCategory\",\"价格\":\"productPrice\",\"状态\":\"productStatus\"},\"originalFieldMap\":{\"商品编号\":\"originalProductId\",\"商品名称\":\"originalProductName\",\"商品分类\":\"originalProductCategory\",\"价格\":\"originalProductPrice\",\"状态\":\"originalProductStatus\"},\"successMessage\":\"已加载商品，可修改后保存\",\"notFoundMessage\":\"未找到匹配商品，请检查编号和名称\",\"multipleMessage\":\"匹配到多条商品，请检查查询条件\"}"
          }
        }
      ],
      "edges": []
    },
    {
